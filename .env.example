WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=
WXRKS_API_URL=https://app.wxrks.com/api/v3
# Primary auth: wxrks API access key/secret pair (POST /auth -> X-AUTH-TOKEN header, auto-refreshed per session).
WXRKS_ACCESS_KEY=
WXRKS_SECRET=
# Optional override: paste a raw X-AUTH-TOKEN value to use directly instead of the accessKey/secret flow.
# Not auto-refreshed -- only useful for short-lived manual testing.
WXRKS_API_TOKEN=
# Optional: pin a specific org unit UUID if the account has more than one (GET /client lists them).
WXRKS_ORG_UNIT_UUID=
APP_BASE_URL=

# Persistence -- settings and sync history are stored in Postgres so they
# survive restarts/deploys. Locally: postgres://localhost/webflow_translation_sync
# On Render: provided automatically by the render.yaml database binding.
DATABASE_URL=

# Email (password reset links, for accounts connected via invite/API token
# rather than "Sign in with Webflow" -- see routes/auth.js's forgot-password
# and services/email.js). Mailgun's HTTP API.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
EMAIL_FROM=

# Server
PORT=3000

# Sync defaults (can be overridden via Settings UI)
SOURCE_LOCALE=en
AUTO_PUBLISH=false
