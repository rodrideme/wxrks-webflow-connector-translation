{
  "name": "webflow-translation-sync",
  "version": "1.0.0",
  "description": "Orchestrates content translation sync between Webflow CMS and wxrks (TMS)",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client:install": "npm install --prefix client",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "build": "npm run client:install && npm run client:build",
    "install:all": "npm install && npm run client:install"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "form-data": "^4.0.6",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
